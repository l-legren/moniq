# Copy to `.env` (gitignored) and fill in.
#
# Local dev (supabase start): use the API_URL / ANON_KEY printed by `supabase start`.
#   EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
#   EXPO_PUBLIC_SUPABASE_ANON_KEY=<ANON_KEY from `supabase start` output>
#
# Hosted project (LEG-47): use the URL/anon key from the Supabase dashboard instead.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
